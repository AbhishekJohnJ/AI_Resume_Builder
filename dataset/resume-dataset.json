    "description": "500 synthetic resume records with structured analysis fields for AI training",
    "schema": {
      "Candidate_ID": "Unique identifier",
      "Name": "Candidate name",
      "Course": "Educational background (CSE, ECE, EEE, BCA, MCA, DS, IT, AIML, Cyber Security)",
      "Target_Domain": "Career target (Web Development, Data Science, Cloud/DevOps, AI/ML, Mobile Development, IoT, Cyber Security)",
      "Skills": "Semicolon-separated technical skills",
      "Projects_Count": "Number of projects completed",
      "Projects": "Comma-separated project names",
      "Certifications_Count": "Number of certifications",
      "Certifications": "Comma-separated certification names",
      "GitHub_Activity_Score": "0-10 scale",
      "LinkedIn_Activity_Score": "0-10 scale",
      "Internships_Count": "Number of internships",
      "Portfolio_Website": "Yes/No",
      "DSA_Score": "0-10 scale",
      "Open_Source_Contributions": "0-5 scale",
      "ATS_Score": "0-100 scale",
      "Resume_Score": "0-100 scale",
      "Resume_Level": "Needs Improvement|Average|Good|Excellent",
      "Weak_Areas": "Pipe-separated weak areas",
      "Suggestions": "Pipe-separated actionable suggestions",
      "Recommended_Tasks": "Pipe-separated recommended tasks"
    }
  },
  "scoringCalibration": {
    "Excellent": { "min": 90, "max": 100 },
    "Good": { "min": 70, "max": 89 },
    "Average": { "min": 50, "max": 69 },
